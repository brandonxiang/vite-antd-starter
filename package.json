{
  "name": "admin-vite-template",
  "version": "1.0.0",
  "scripts": {
    "start": "cross-env APP_ENV=test vite",
    "build:test": "cross-env APP_ENV=test vite build",
    "build:uat": "cross-env APP_ENV=uat vite build",
    "build": "cross-env APP_ENV=live vite build",
