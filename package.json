{
  "name": "admin-vite-template",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server --config vite-server.config.ts",
    "build": "vite build --outDir dist/static && npm run build:server && node prerender.mjs",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "optionalDependencies": {
    "@commitlint/cli": "17.6.7",
    "@commitlint/config-conventional": "17.6.7",
    "husky": "8.0.3",
    "lint-staged": "13.2.3"
  },
  "devDependencies": {
    "@types/node": "18.17.1",
    "@types/react": "^18.2.17",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "6.2.0",
    "@typescript-eslint/parser": "6.2.0",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "cross-env": "7.0.3",
    "eslint": "8.45.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-prettier": "5.0.0",
    "eslint-plugin-react": "7.33.0",
    "eslint-plugin-react-hooks": "4.6.0",
    "prettier": "^3.0.3",
    "sass": "1.64.1",
    "taze": "^0.11.2",
    "typescript": "5.1.6",
    "vite": "^4.4.7",
    "vite-plugin-html": "3.2.0"
  },
  "dependencies": {
    "@ant-design/icons": "5.1.4",
    "antd": "5.7.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^6.14.2",
    "react-router-dom": "^6.14.2"
  }
}
